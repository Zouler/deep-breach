{
  "expo": {
    "name": "Deep Breach",
    "slug": "deep-breach",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/branding/expo-app-icon.png",
    "scheme": "deepbreach",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/branding/expo-splash-portrait.png",
      "resizeMode": "cover",
      "backgroundColor": "#030712"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/expo-adaptive-icon.png",
        "backgroundColor": "#030712"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
